     7	def calculate_wmi_rawgame(df):
     8	    # Definition formula:
     9	    # M_t = F_t(1 + N_t) = F_t + F_t*N_t
    10	    # WMI_rawgame = [ (1 / n1) * sum_{t: L_t=1} M_t ] / [ (1 / n0) * sum_{t: L_t=0} M_t ]
    11	    l = df["L_t"].astype(float)
    12	    f = df["F_t"].astype(float)
    13	    n = df["N_t"].astype(float)
    14	    m = f + (f * n)
    15	
    16	    group_l1 = m[l == 1.0]
    17	    group_l0 = m[l == 0.0]
    18	
    19	    n1 = int(group_l1.shape[0])
    20	    n0 = int(group_l0.shape[0])
