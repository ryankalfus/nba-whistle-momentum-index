    "review::.::holistic::api_surface_coherence::mixed_failure_contracts_across_builders::d139415b": {
      "id": "review::.::holistic::api_surface_coherence::mixed_failure_contracts_across_builders::d139415b",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Closely related builder functions alternate between raising, returning `None`, and returning status dictionaries.",
      "detail": {
        "holistic": true,
        "dimension": "api_surface_coherence",
        "related_files": [
          "calculate_wmi_rawseason_2024_25.py",
          "step2_build_possessions.py",
          "build_possession_model_table_okc_mil.py",
          "categorize_defensive_fouls_okc_mil.py",
          "calculate_wmi_rawseason_2010_11_to_2023_24.py"
        ],
        "evidence": [
          "`build_possession_table_for_game` in `calculate_wmi_rawseason_2024_25.py` returns `None` when actions are empty, when game time cannot be computed, or when the team count is not two.",
          "`parse_possessions` in `step2_build_possessions.py` raises `ValueError(\"Expected exactly 2 team IDs in game data.\")` for the same kind of malformed input instead of returning `None`.",
          "`process_game` in `calculate_wmi_rawseason_2010_11_to_2023_24.py` wraps failures into dictionaries like `{\"status\": \"missing\"}` or `{\"status\": \"error\"}`, while `build_table` and `build_def_foul_context` let `requests.get(...).raise_for_status()` exceptions escape directly."
        ],
        "suggestion": "Pick one public error contract for this pipeline, for example typed exceptions or a single result object with `status`, `data`, and `error`, and apply it to all builder/fetch functions so callers can handle failures the same way everywhere.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-06T16:42:13+00:00",
      "last_seen": "2026-03-06T16:42:13+00:00",
      "resolved_at": null,
